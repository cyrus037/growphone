# Required
MONGODB_URI=mongodb://127.0.0.1:27017/growphone

# JWT for /api/auth/login and all protected admin routes (Bearer token)
JWT_SECRET=change-me-to-a-long-random-string-in-production

# CORS (comma-separated allowed origins — include http://localhost:5173 for local dev)
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173,https://quiet-licorice-3ad6e3.netlify.app,https://growphone.in,https://www.growphone.in
PORT=5000

# Optional: emergency login when Admin Panel is disabled in MongoDB (send as recoveryKey in POST /api/auth/login)
ADMIN_RECOVERY_KEY=

# Optional: user email for secret_key-only login mode (defaults to admin@growphone.in)
ADMIN_EMAIL=admin@growphone.in

# --- SMTP: Zoho Mail (info@growphone.in) ---
# In Zoho: Mail → Settings → Mail Accounts → IMAP / SMTP — copy the SMTP host shown for your region.
# Common: smtp.zoho.com (port 587 TLS) or port 465 SSL. India-hosted accounts may use smtp.zoho.in — check Zoho.
# Use the mailbox password, or an App Password if Zoho requires 2FA.

