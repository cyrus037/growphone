# Local development (recommended)
# Leave empty: the Vite dev server proxies /api to http://localhost:5000 (see vite.config.js).
# Run API: cd server && npm run dev
# Run app: cd client && npm run dev
VITE_API_URL=

# Optional: call the API directly (no proxy). Must match CORS CLIENT_URL on the server.
# VITE_API_URL=http://localhost:5000
